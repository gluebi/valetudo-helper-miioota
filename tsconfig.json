{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "app.ts",
    "Logger.ts",
    "commands/**/*.ts",
    "miio/**/*.ts",
    "utils/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "build", "tests"]
}
